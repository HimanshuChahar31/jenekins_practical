pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo "Code checkout completed"
            }
        }

        stage('Build') {
            steps {
                echo "Building Project"
            }
        }

        stage('Test') {
            steps {
                echo "Running Tests"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deployment Successful"
            }
        }

    }
}
